---
import LayoutBase from '../layouts/LayoutBase.astro'
import CTAButton from '../components/CTAButton.astro'
import StickyHeader from '../components/StickyHeader.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'
import { Icon } from 'astro-icon/components'

// TODO: substituir pelo link real do Hotmart
const HOTMART_LINK = '#TODO-link-hotmart'
---
<LayoutBase
  title="Acelerador de Resultados · Método AME | Dra. Márcia Rocha"
  description="O programa de acompanhamento personalizado da Dra. Márcia Rocha para mulheres 40+ que querem emagrecer definitivamente."
>
  <StickyHeader />
  <WhatsAppButton />

  <!-- D01 — HERO -->
  <section id="dobra-01" class="bg-bg relative overflow-hidden">
    <div
      class="absolute top-[-80px] right-[-60px] w-[480px] h-[480px] rounded-full pointer-events-none z-0"
      style="background: radial-gradient(circle, rgba(184,154,106,0.12) 0%, transparent 70%);"
    ></div>
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px] relative z-10">
      <div class="flex flex-col md:flex-row md:items-center md:gap-12">
        <div class="md:w-[58%] order-2 md:order-1">
          <p class="font-body font-semibold text-primary text-[11px] uppercase tracking-[0.1em] mb-6">
            Acelerador de Resultados · Método AME
          </p>
          <h1
            class="font-heading font-bold text-text leading-[1.18] mb-6"
            style="font-size: clamp(24px, 2.8vw, 44px);"
          >
            Ative o metabolismo, emagreça de forma definitiva e recupere a energia que você achava que tinha perdido.
          </h1>
          <p class="font-body text-muted leading-[1.65] text-[15px] md:text-[17px] max-w-[65ch]">
            O programa de acompanhamento personalizado da Dra. Márcia Rocha para mulheres 40+ que querem emagrecer definitivamente.
          </p>
        </div>
        <div class="md:w-[42%] order-1 md:order-2 mb-8 md:mb-0">
          <div
            class="relative w-full rounded-[20px] overflow-hidden"
            style="aspect-ratio: 3/4; max-height: 520px; box-shadow: 0 16px 48px rgba(62,44,36,0.16);"
          >
            <img
              src="/images/hero-marcia-quente.jpg"
              alt="Dra. Márcia Rocha — médica especialista em Nutrologia e Medicina Integrativa"
              class="w-full h-full object-cover object-top"
              loading="eager"
              fetchpriority="high"
            />
            <div
              class="absolute inset-0 pointer-events-none"
              style="background: linear-gradient(to top, rgba(242,238,231,0.5) 0%, transparent 20%);"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- D02 — PROBLEMA -->
  <section id="dobra-02" class="bg-surface">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.22] text-center mb-12 will-animate">
        Você se identifica com isso?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {[
          { frase: 'Já tentei várias dietas e nada funciona de verdade.', delay: '0' },
          { frase: 'Perco peso mas sempre ganho tudo de volta.', delay: '100' },
          { frase: 'Sinto fome o tempo todo ou como por ansiedade.', delay: '200' },
          { frase: 'Estou sempre cansada, sem energia.', delay: '300' },
          { frase: 'Sinto inchaço, retenção de líquido, intestino desregulado.', delay: '400' },
          { frase: 'O que funcionava antes não funciona mais depois dos 40.', delay: '500' },
        ].map((item) => (
          <div
            class="relative bg-bg rounded-card px-7 pt-10 pb-7 will-animate"
            data-delay={item.delay}
            style="border: 1px solid rgba(62,44,36,0.08); box-shadow: 0 2px 8px rgba(62,44,36,0.08);"
          >
            <span
              class="absolute top-0 left-4 font-heading italic text-primary leading-none pointer-events-none select-none"
              style="font-size: 56px; opacity: 0.3; line-height: 1;"
              aria-hidden="true"
            >&ldquo;</span>
            <p class="font-body text-text text-[15px] md:text-[16px] leading-[1.65]">{item.frase}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center will-animate" data-delay="600">
        <div class="w-20 h-px bg-primary opacity-20 mx-auto mb-6"></div>
        <p class="font-body font-medium text-text text-[16px] md:text-[18px] max-w-[600px] mx-auto">
          A culpa não é sua. É o metabolismo que mudou.
        </p>
      </div>
    </div>
  </section>

  <!-- D03 — OPORTUNIDADE -->
  <section id="dobra-03" class="bg-bg">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.18] text-center max-w-[600px] mx-auto will-animate">
        O que a medicina convencional não te conta sobre o metabolismo depois dos 40
      </h2>
      <div class="w-20 h-px bg-primary opacity-20 mx-auto mt-8 mb-10 will-animate" data-delay="100"></div>
      <div class="max-w-[760px] mx-auto">
        <p class="font-body text-text text-[15px] md:text-[17px] leading-[1.65] text-center md:text-left mb-6 will-animate" data-delay="200">
          O corpo da mulher 40+ não parou de funcionar. Ele está funcionando de acordo com regras novas, e responde muito bem quando você aprende essas regras.
        </p>
        <p class="font-body text-text text-[15px] md:text-[17px] leading-[1.65] text-center md:text-left mb-6 will-animate" data-delay="300">
          O problema é que o modelo convencional oferece dois caminhos para esse momento: remédio ou restrição. O remédio mascara o sintoma sem tratar a base. A restrição aumenta o cortisol e trava o metabolismo ainda mais.
        </p>
        <p class="font-body font-medium text-text text-[15px] md:text-[17px] leading-[1.65] text-center md:text-left will-animate" data-delay="400">
          Existe um terceiro caminho. E ele começa por ativar o que já está no seu corpo, não por forçar algo que ele não está preparado para fazer.
        </p>
      </div>
    </div>
  </section>

  <!-- D04 — VÍDEO -->
  <section id="dobra-04" class="bg-surface">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.18] text-center will-animate">
        Assista: Como funciona o Acelerador de Resultados
      </h2>
      <p class="font-body text-muted text-[15px] md:text-[17px] text-center mt-3 will-animate" data-delay="100">
        3 minutos para entender como ativar seu metabolismo.
      </p>
      <div
        id="video-facade"
        class="max-w-[860px] mx-auto mt-10 rounded-card overflow-hidden relative cursor-pointer will-animate md:rounded-card rounded-none"
        data-delay="200"
        style="aspect-ratio: 16/9; box-shadow: 0 16px 48px rgba(62,44,36,0.16);"
      >
        <div id="video-thumbnail" class="w-full h-full bg-secondary/20 flex items-center justify-center">
          <span class="font-body text-[12px] text-muted tracking-widest uppercase">Thumbnail do vídeo</span>
        </div>
        <div class="absolute inset-0 bg-text/30 pointer-events-none" id="video-overlay"></div>
        <button
          id="video-play-btn"
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60px] h-[60px] md:w-[72px] md:h-[72px] bg-bg rounded-full flex items-center justify-center transition-all duration-200 hover:bg-surface hover:scale-[1.06] focus-visible:outline-2 focus-visible:outline-primary"
          style="box-shadow: 0 8px 24px rgba(0,0,0,0.15);"
          aria-label="Reproduzir vídeo"
        >
          <Icon name="ph:play-fill" size={32} class="text-primary ml-1" />
        </button>
        <div id="video-iframe-container" class="hidden absolute inset-0"></div>
      </div>
    </div>
  </section>

  <!-- D05 — PROVA SOCIAL -->
  <section id="dobra-05" class="grain-overlay relative" style="background:#8A5A44;">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-[26px] md:text-[34px] leading-[1.18] text-center mb-12 will-animate" style="color:#F2EEE7;">
        O que acontece quando o metabolismo é tratado na causa
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
        {[
          { nome: 'Ana C.', perfil: 'Fome Desregulada', depoimento: 'Depois de anos tentando de tudo, finalmente entendi o que estava acontecendo no meu corpo. Em 3 meses já sentia a diferença na energia e no humor.', resultado: 'Perdeu 8kg em 4 meses · Parou com compulsão alimentar', img: 'depoimento-01-resultado.jpg', delay: '0' },
          { nome: 'Carla M.', perfil: 'Energia Baixa', depoimento: 'Achei que era só cansaço da idade. A Dra. Márcia mostrou que era o metabolismo operando em modo economia. Hoje acordo disposta e sem depender de café.', resultado: 'Perdeu 11kg em 5 meses · Energia recuperada', img: 'depoimento-02-resultado.jpg', delay: '100' },
          { nome: 'Renata S.', perfil: 'Inflamação Metabólica', depoimento: 'O inchaço que me acompanhava há anos sumiu nas primeiras semanas. Não acreditava que era possível sem remédio.', resultado: 'Perdeu 7kg em 3 meses · Fim do inchaço crônico', img: 'depoimento-03-resultado.jpg', delay: '200' },
          { nome: 'Patrícia L.', perfil: 'Fome Desregulada', depoimento: 'O programa me deu estrutura e uma nutricionista que acompanha de perto. Pela primeira vez não sinto que estou sozinha nessa jornada.', resultado: 'Perdeu 14kg em 6 meses · Autonomia alimentar consolidada', img: 'depoimento-04-resultado.jpg', delay: '300' },
        ].map((item) => (
          <div
            class="bg-bg rounded-card will-animate"
            data-delay={item.delay}
            style="padding: 28px 32px; box-shadow: 0 4px 16px rgba(62,44,36,0.12);"
          >
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-full overflow-hidden shrink-0 bg-surface flex items-center justify-center" style="border: 2px solid #B89A6A;">
                <img src={`/images/${item.img}`} alt={`Foto de ${item.nome}`} class="w-full h-full object-cover" loading="lazy" decoding="async" />
              </div>
              <div>
                <p class="font-body font-semibold text-text text-[14px]">{item.nome}</p>
                <p class="font-body font-medium text-muted text-[12px] uppercase tracking-[0.08em]">{item.perfil}</p>
              </div>
            </div>
            <div class="h-px bg-surface mt-3 mb-4"></div>
            <p class="font-body text-text text-[15px] leading-[1.65] italic mb-3">&ldquo;{item.depoimento}&rdquo;</p>
            <p class="font-body font-bold text-secondary text-[14px]">{item.resultado}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- D06 — PERFIS METABÓLICOS -->
  <section id="dobra-06" class="bg-bg">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.18] text-center will-animate">
        Qual é o seu perfil metabólico?
      </h2>
      <p class="font-body text-muted text-[15px] md:text-[17px] leading-[1.65] text-center mt-4 mb-12 max-w-[65ch] mx-auto will-animate" data-delay="100">
        Não existe estratégia genérica. Cada perfil precisa de uma estratégia completamente diferente.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { emoji: '🌸', nome: 'Fome Desregulada', cor: '#cc66cc', bg: 'rgba(255,173,255,0.15)', texto: '"Você belisca o dia todo, come quando está ansiosa e sente culpa depois. Não é fraqueza, é cortisol alto e glicose em montanha-russa pedindo regulação, não restrição."', borda: '#ffadff', delay: '0' },
          { emoji: '💜', nome: 'Energia Baixa', cor: '#7a55dd', bg: 'rgba(158,125,255,0.15)', texto: '"Você acorda sem disposição, depende de café para funcionar e entra em colapso no meio da tarde. Não é preguiça, é o metabolismo operando em modo de economia forçada por falta dos nutrientes certos."', borda: '#9e7dff', delay: '150' },
          { emoji: '🧡', nome: 'Inflamação Metabólica', cor: '#dd6633', bg: 'rgba(255,153,102,0.15)', texto: '"Você tem inchaço abdominal, retenção de líquido, dores no corpo e intestino irregular. Não é azar, é inflamação silenciosa que retém peso por proteção e que responde quando tratada na raiz."', borda: '#ff9966', delay: '300' },
        ].map((p) => (
          <div
            class="bg-bg rounded-card p-8 will-animate transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
            data-delay={p.delay}
            style={`border: 1px solid rgba(62,44,36,0.08); border-top: 3px solid ${p.borda}; box-shadow: 0 2px 8px rgba(62,44,36,0.08);`}
          >
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-5 text-4xl" style={`background: ${p.bg};`}>
              {p.emoji}
            </div>
            <h3 class="font-heading font-semibold text-[20px] leading-[1.3] mb-4" style={`color: ${p.cor};`}>{p.nome}</h3>
            <p class="font-body text-text text-[15px] leading-[1.65] italic">{p.texto}</p>
          </div>
        ))}
      </div>
      <p class="font-body font-medium text-text text-[16px] text-center mt-12 max-w-[640px] mx-auto will-animate" data-delay="450">
        O diagnóstico do seu perfil acontece na primeira sessão com a Dra. Márcia. Tudo o que vem depois é construído em cima dele.
      </p>
    </div>
  </section>

  <!-- D07 — JORNADA -->
  <section id="dobra-07" class="bg-surface">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.18] text-center mb-12 will-animate">
        Sua jornada de 6 meses
      </h2>
      <div class="max-w-[800px] mx-auto flex flex-col gap-4">
        {[
          { badge: '⭐', fase: 'Fase 1: Despertando', semanas: 'Semanas 1–2', desc: 'Acordar o metabolismo, desinflamação inicial, ajuste de sono e hidratação.', delay: '0' },
          { badge: '⭐⭐', fase: 'Fase 2: Reacendendo', semanas: 'Semanas 3–4', desc: 'Primeiros resultados visíveis, intensificação gradual, introdução de exercícios.', delay: '100' },
          { badge: '⭐⭐⭐', fase: 'Fase 3: Impulsionado', semanas: 'Semanas 5–12', desc: 'Potencializar emagrecimento, ciclagem de cardápios, força e definição.', delay: '200' },
          { badge: '⭐⭐⭐⭐', fase: 'Fase 4: Ativado', semanas: 'Semanas 13–24', desc: 'Manutenção inteligente, prevenção de recaídas, autonomia consolidada.', delay: '300' },
        ].map((item) => (
          <div
            class="bg-bg rounded-[12px] px-7 py-6 flex flex-col md:flex-row md:items-start gap-4 will-animate transition-all duration-[250ms] hover:shadow-md"
            data-delay={item.delay}
            style="border-left: 4px solid #B89A6A; box-shadow: 0 2px 8px rgba(62,44,36,0.08);"
          >
            <div class="shrink-0 font-body font-medium text-[14px] rounded-[8px] px-[10px] py-1 self-start" style="background: rgba(184,154,106,0.12);">
              {item.badge}
            </div>
            <div>
              <p class="font-heading font-semibold text-text text-[18px] leading-[1.3]">{item.fase}</p>
              <p class="font-body font-medium text-muted text-[12px] uppercase tracking-[0.08em] mt-0.5 mb-2">{item.semanas}</p>
              <p class="font-body text-text text-[15px] leading-[1.6]">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- D08 — ENTREGÁVEIS -->
  <section id="dobra-08" class="bg-bg">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.18] text-center will-animate">
        Tudo que você vai receber
      </h2>
      <p class="font-body text-muted text-[15px] md:text-[17px] text-center mt-4 mb-12 max-w-[65ch] mx-auto will-animate" data-delay="100">
        Para ativar o metabolismo e emagrecer de forma definitiva nos próximos 6 meses:
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'ph:stethoscope', titulo: 'Diagnóstico individual completo', desc: 'Seu ponto de partida personalizado, com sessão individual, lista de exames recomendados e plano de ação por escrito.', delay: '0' },
          { icon: 'ph:device-mobile', titulo: 'App com plano personalizado', desc: 'Cada semana você abre o app e encontra as estratégias da sua fase, o cardápio e a lista de suplementos.', delay: '50' },
          { icon: 'ph:user-circle', titulo: 'Acompanhamento nutricional', desc: 'A nutricionista Bianca verifica se o plano está sendo executado, identifica o que está travando e faz os ajustes antes que virem problemas.', delay: '100' },
          { icon: 'ph:calendar-check', titulo: '6 sessões individuais', desc: 'Acompanhamento mensal com a Dra. Márcia ou com a nutricionista, para reavaliação completa do progresso e ajuste do plano.', delay: '150' },
          { icon: 'ph:video-camera', titulo: '12 encontros ao vivo', desc: '2x por mês em grupo, com a Dra. Márcia, com perguntas respondidas ao vivo e mini-aulas temáticas. Sempre gravado para quem não puder ao vivo.', delay: '200' },
          { icon: 'ph:headphones', titulo: 'Áudios diários', desc: 'Todos os dias, um áudio da Dra. Márcia para manter a mentalidade no lugar certo mesmo quando a rotina aperta.', delay: '250' },
          { icon: 'ph:map-trifold', titulo: 'Guias para situações especiais', desc: 'Viagens, festas, finais de semana, TPM, família que não apoia. Para que a vida real não derrube o que você construiu durante a semana.', delay: '300' },
          { icon: 'ph:graduation-cap', titulo: 'Curso Método AME', desc: 'Acesso completo ao conteúdo educativo do método para quem quer entender a fundo o que está acontecendo no próprio corpo.', delay: '350' },
          { icon: 'ph:pill', titulo: 'Suplementação personalizada', desc: 'Lista de suplementos e fitoterápicos adequados ao seu perfil, com dosagens e horários definidos pela Dra. Márcia e ajustados a cada reavaliação mensal.', delay: '400' },
        ].map((item) => (
          <div
            class="bg-bg rounded-card px-6 py-7 text-left will-animate transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
            data-delay={item.delay}
            style="border: 1px solid rgba(62,44,36,0.08); box-shadow: 0 2px 8px rgba(62,44,36,0.08);"
          >
            <div class="w-[52px] h-[52px] rounded-[12px] flex items-center justify-center mb-4" style="background: rgba(184,154,106,0.10);">
              <Icon name={item.icon} size={24} class="text-primary" />
            </div>
            <h3 class="font-heading font-semibold text-text text-[18px] leading-[1.3] mb-2">{item.titulo}</h3>
            <p class="font-body text-muted text-[14px] leading-[1.6]">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="font-body font-medium text-text text-[16px] text-center mt-12 max-w-[640px] mx-auto will-animate" data-delay="450">
        Tudo organizado para que você nunca precise adivinhar o próximo passo.
      </p>
    </div>
  </section>

  <!-- D09 — APP -->
  <section id="dobra-09" class="bg-surface">
    <div class="max-w-container mx-auto px-5 md:px-10 py-16 md:py-[100px]">
      <h2 class="font-heading font-bold text-text text-[26px] md:text-[34px] leading-[1.18] text-center will-animate">
        Seu plano, organizado semana a semana
      </h2>
      <p class="font-body text-muted text-[15px] md:text-[17px] text-center mt-4 mb-16 max-w-[65ch] mx-auto will-animate" data-delay="100">
        Não precisa adivinhar o que fazer. Tudo vem direcionado para você.
      </p>
      <div class="flex flex-col gap-16 md:gap-24">
        {[
          { side: 'left', titulo: 'Tudo que você precisa, em um só lugar.', items: ['Mensagem personalizada da Dra. Márcia', 'Estratégias específicas da sua fase', 'Cardápio da semana em PDF', 'Lista de suplementos com horários', 'Checkboxes diários para acompanhar'], img: 'app-mockup-plano.jpg' },
          { side: 'right', titulo: 'Acompanhe sua evolução.', items: ['Gráfico de peso e tendência', 'Galeria de fotos de progresso', 'Sequência de dias (streak)', 'Histórico completo'], img: 'app-mockup-progresso.jpg' },
          { side: 'left', titulo: 'Tudo personalizado para você.', items: ['Características do seu perfil', 'Suplementos específicos', 'Próximas reavaliações', 'Progresso e metas'], img: 'app-mockup-perfil.jpg' },
        ].map((bloco) => (
          <div class={`flex flex-col ${bloco.side === 'right' ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-10 md:gap-20`}>
            <div class="w-full md:w-[42%] flex justify-center will-animate" data-delay="0">
              <div class="relative" style="width: 220px; min-width: 200px;">
                <div class="relative overflow-hidden" style="border-radius: 40px; border: 10px solid #3E2C24; aspect-ratio: 9/19; box-shadow: 0 25px 60px rgba(62,44,36,0.20);">
                  <div class="absolute top-3 left-1/2 -translate-x-1/2 z-10" style="width: 70px; height: 18px; background: #3E2C24; border-radius: 10px;"></div>
                  <div class="w-full h-full relative" style="background: linear-gradient(160deg, #F2EEE7 0%, #D8CBBE 100%);">
                    <img src={`/images/${bloco.img}`} alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" style="display:block;" />
                  </div>
                </div>
              </div>
            </div>
            <div class="w-full md:w-[58%] will-animate" data-delay="150">
              <h3 class="font-heading font-semibold text-text text-[20px] md:text-[22px] leading-[1.28] mb-6">{bloco.titulo}</h3>
              <ul class="flex flex-col gap-3">
                {bloco.items.map((item) => (
                  <li class="flex items-center gap-3">
                    <span class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: #B89A6A;">
                      <Icon name="ph:check-bold" size={12} style="color: white;" />
                    </span>
                    <span class="font-body text-text text-[15px]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
