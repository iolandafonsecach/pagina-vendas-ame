---
// TODO: substituir pelo número real — formato: 5511999999999
const whatsappNumber = 'TODO-NUMERO'
const href = `https://wa.me/${whatsappNumber}`
---
<a
  id="whatsapp-btn"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar com a equipe pelo WhatsApp"
  class="group fixed bottom-6 right-5 md:bottom-8 md:right-8 z-50 flex items-center justify-center w-14 h-14 rounded-full hover:scale-[1.06] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366] whatsapp-pulse"
  style="background:#25D366; box-shadow: 0 4px 20px rgba(37,211,102,0.5), 0 2px 8px rgba(0,0,0,0.20); opacity:0; pointer-events:none; transition: opacity 0.3s ease, transform 0.2s ease;"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 256 256" fill="white">
    <path d="M187.58,144.84l-32-16a8,8,0,0,0-8,.5l-14.69,9.8a40.55,40.55,0,0,1-16-16l9.8-14.68a8,8,0,0,0,.5-8l-16-32A8,8,0,0,0,104,64a40,40,0,0,0-40,40,88.1,88.1,0,0,0,88,88,40,40,0,0,0,40-40A8,8,0,0,0,187.58,144.84ZM152,176a72.08,72.08,0,0,1-72-72,24,24,0,0,1,19.29-23.54l13.19,26.38-9.3,13.95a8,8,0,0,0-.57,7.61,56.45,56.45,0,0,0,30,30,8,8,0,0,0,7.61-.57l13.95-9.3,26.38,13.19A24,24,0,0,1,152,176ZM128,24a104,104,0,0,0-91.82,152.88L24.2,211.46a16,16,0,0,0,20.34,20.34l34.58-11.98A104,104,0,1,0,128,24Zm0,192a88,88,0,0,1-44.06-11.81,8,8,0,0,0-6.54-.67L40,216l12.48-37.4a8,8,0,0,0-.67-6.54A88,88,0,1,1,128,216Z"/>
  </svg>
  <!-- Tooltip desktop -->
  <span
    class="absolute right-16 whitespace-nowrap bg-text text-bg font-body text-xs px-3 py-1.5 rounded-badge opacity-0 group-hover:opacity-100 transition-opacity duration-150 pointer-events-none hidden md:block"
  >
    Falar com a equipe
  </span>
</a>

<script>
  function initWhatsAppButton() {
    const btn = document.getElementById('whatsapp-btn') as HTMLElement
    const trigger = document.getElementById('dobra-03')
    if (!btn || !trigger) return

    const observer = new IntersectionObserver(
      ([entry]) => {
        const visible = !entry.isIntersecting && entry.boundingClientRect.top < 0
        btn.style.opacity = visible ? '1' : '0'
        btn.style.pointerEvents = visible ? 'auto' : 'none'
      },
      { threshold: 0 }
    )
    observer.observe(trigger)
  }

  document.addEventListener('DOMContentLoaded', initWhatsAppButton)
</script>
